{
  "display_name": "Unsecured Credentials - T1552",
  "mid": "T1552",
  "controls": [
    "api-keys-not-restricted-to-specified-apis",
    "api-keys-not-restricted-to-specified-hosts-and-apps",
    "api-keys-not-rotated-90-days",
    "aws-ecs-8-secrets-in-vars",
    "azure-expiration-secrets-key-vault",
    "azure-key-vaults-store-secrets",
    "gcp-secrets-not-in-env-variables",
    "k8s-minimize-access-to-secrets",
    "k8s-prefer-using-secrets-as-files-over-secrets-as-env-var",
    "k8s-use-external-secret-storage"
  ],
  "assets": [
    "Connector",
    "User",
    "IAMUser",
    "IAMRole",
    "IAMServiceAccount",
    "ManagedIdentity",
    "KMSSecret",
    "KMSKey"
  ],
  "propagators": [
    "IAMPolicy"
  ]
}
